{
  "entities": {
    "OrderItem": {
      "title": "OrderItem",
      "description": "A single item within an order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" }
      },
      "required": ["id", "name", "quantity", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A delivery order from a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "OrderItem" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["placed", "accepted", "picked", "out_for_delivery", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "vendorId": { "type": "string" },
        "riderId": { "type": "string" },
        "isPriority": { "type": "boolean" },
        "pickupCoords": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "deliveryCoords": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "riderCoords": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["id", "customerName", "address", "total", "status", "createdAt", "vendorId"]
    },
    "VendorProfile": {
      "title": "VendorProfile",
      "description": "Subscription and usage data for a vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "dailyOrderCount": { "type": "number" },
        "lastResetDate": { "type": "string" }
      },
      "required": ["id", "email", "plan", "dailyOrderCount", "lastResetDate"]
    },
    "Product": {
      "title": "Product",
      "description": "An item available for sale in a store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "vendorId": { "type": "string" }
      },
      "required": ["name", "price", "stock", "category", "vendorId"]
    },
    "RiderProfile": {
      "title": "RiderProfile",
      "description": "Stats and availability for a delivery rider",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "dailyDeliveries": { "type": "number" },
        "weeklyDeliveries": { "type": "number" },
        "totalEarnings": { "type": "number" }
      },
      "required": ["id", "email", "isOnline"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Multi-role account information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string", "enum": ["vendor", "rider"] } },
        "displayName": { "type": "string" }
      },
      "required": ["id", "roles", "displayName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Partner user profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global orders collection"
    },
    "/vendors/{vendorId}": {
      "schema": "VendorProfile",
      "description": "Vendor subscription and usage data"
    },
    "/riders/{riderId}": {
      "schema": "RiderProfile",
      "description": "Rider stats and availability"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products across all stores"
    }
  }
}
